# ─── URL & environnement ─────────────────────────────────────────────
# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://maxou-officiel.fr
# Mettre "production" pour autoriser l'indexation (robots.ts)
NEXT_PUBLIC_ENV=development

# ─── Resend — formulaire de contact + newsletter ─────────────────────
# Clé API Resend (en prod : wrangler secret put RESEND_API_KEY)
RESEND_API_KEY=
# Expéditeur vérifié sur Resend (domaine validé)
RESEND_FROM_EMAIL=contact@maxou-officiel.fr
# Destinataire des demandes de contact (défaut : email du site-config)
CONTACT_RECIPIENT_EMAIL=
# Destinataire des inscriptions newsletter (défaut : email du site-config)
NEWSLETTER_RECIPIENT_EMAIL=
